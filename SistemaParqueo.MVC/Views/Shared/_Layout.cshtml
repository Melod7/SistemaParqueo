<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema de Parqueo Vehicular</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>

    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark shadow">
            <div class="container-fluid">

                <a class="navbar-brand" asp-controller="Parqueo" asp-action="Dashboard">
                    🚗 Sistema Parqueo
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="menu">

                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Parqueo" asp-action="Dashboard">
                                Dashboard
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Parqueo" asp-action="Ingreso">
                                Registrar Ingreso
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Parqueo" asp-action="Salida">
                                Registrar Salida
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Parqueo" asp-action="Activos">
                                Vehículos Activos
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Parqueo" asp-action="Historial">
                                Historial
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Parqueo" asp-action="Reporte">
                                Reportes
                            </a>
                        </li>

                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container text-center">
            © 2026 - Sistema de Parqueo Vehicular
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>